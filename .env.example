PORT=8787
PUBLIC_API_BASE_URL=http://localhost:8787

UIPATH_ENABLED=false
UIPATH_FOLDER_PATH=
UIPATH_BUCKET_KEY=
UIPATH_QUEUE_NAME=InvoiceIntake

UIPATH_START_CASE=false
UIPATH_CASE_FOLDER_KEY=
# Use the Maestro/Orchestrator ProcessKey string, not the process/release UUID Key.
# Example: QoyodInvoiceIntakeCase.case.Case
UIPATH_CASE_PROCESS_KEY=
# Use the Orchestrator process Key UUID as the Case release key.
UIPATH_CASE_RELEASE_KEY=
# Keep false in staging unless `uip maestro case process run --validate` works for Case packages.
UIPATH_CASE_VALIDATE_INPUTS=false
UIPATH_CASE_FEED_ID=

EXTRACTION_MODE=local
EXTRACTION_START_URL=
EXTRACTION_CALLBACK_TOKEN=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_EXTRACTION_MODEL=gpt-4.1
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

INTAKE_WEBHOOK_TOKEN=
FILLER_API_TOKEN=
CASE_CALLBACK_TOKEN=
