        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:(vars.caseManagerDecisions.stagesExited == null || vars.caseManagerDecisions.stagesExited.length == 0 || !vars.caseManagerDecisions.stagesExited.some((stage) =&gt; stage.stageName == 'Capture Intake' || stage.stageName == 'Extraction And Reconciliation' || stage.stageName == 'Finance Review And Mapping' || stage.stageName == 'Destination Posting' || stage.stageName == 'Qoyod Drafting' || stage.stageName == 'Exception Resolution' || stage.stageName == 'Closed')) &amp;&amp; (vars.caseManagerDecisions.stagesCompleted == null || vars.caseManagerDecisions.stagesCompleted.length == 0 || !vars.caseManagerDecisions.stagesCompleted.some((stage) =&gt; stage.stageName == 'Capture Intake' || stage.stageName == 'Extraction And Reconciliation' || stage.stageName == 'Finance Review And Mapping' || stage.stageName == 'Destination Posting' || stage.stageName == 'Qoyod Drafting' || stage.stageName == 'Exception Resolution' || stage.stageName == 'Closed'))</bpmn:conditionExpression>
