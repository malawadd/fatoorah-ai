        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:((vars.caseManagerDecisions.stagesExited != null &amp;&amp; vars.caseManagerDecisions.stagesExited.length &gt; 0 &amp;&amp; vars.caseManagerDecisions.stagesExited.some((stage) =&gt; stage.stageName == 'Closed')) || (vars.caseManagerDecisions.stagesCompleted != null &amp;&amp; vars.caseManagerDecisions.stagesCompleted.length &gt; 0 &amp;&amp; vars.caseManagerDecisions.stagesCompleted.some((stage) =&gt; stage.stageName == 'Closed')))</bpmn:conditionExpression>
