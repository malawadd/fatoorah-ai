        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:(vars.caseManagerDecisions.stagesEntered.some((stage) =&gt; stage.stageName == 'Capture Intake'))</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="edge_eventSubprocessStagesEnteredInclusiveGateway-startStageSlaMessageEvent_Stage_Y4pLq8" sourceRef="eventSubprocessStagesEnteredInclusiveGateway" targetRef="startStageSlaMessageEvent_Stage_Y4pLq8">
