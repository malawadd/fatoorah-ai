{
  "document": {
    "dsl": "1.0.0",
    "name": "QoyodCaseWaitForQoyodExtensionDraft",
    "version": "0.1.0",
    "namespace": "qoyod.invoiceIntake.case",
    "metadata": {
      "variables": {
        "schema": {
          "format": "json",
          "document": {
            "type": "object",
            "properties": {
              "decision": { "type": "object", "default": {} },
              "attempt": { "type": "number", "default": 0 },
              "done": { "type": "boolean", "default": false }
            },
            "title": "Variables"
          }
        }
      }
    }
  },
  "input": {
    "schema": {
      "format": "json",
      "document": {
        "type": "object",
        "properties": {
          "apiBaseUrl": { "type": "string" },
          "caseCallbackToken": { "type": "string" },
          "batchId": { "type": "string" },
          "caseJobKey": { "type": "string" },
          "caseInstanceId": { "type": "string" },
          "maxAttempts": { "type": "number" }
        },
        "required": ["apiBaseUrl", "batchId"],
        "title": "Inputs"
      }
    }
  },
  "output": {
    "schema": {
      "format": "json",
      "document": {
        "type": "object",
        "properties": {
          "caseStage": { "type": "string" },
          "caseStatus": { "type": "string" },
          "taskStatus": { "type": "string" },
          "qoyodDraftStatus": { "type": "string" },
          "qoyodDraftReference": { "type": "string" },
          "errorCode": { "type": "string" }
        },
        "title": "Outputs"
      }
    }
  },
  "do": [
    {
      "Sequence_1": {
        "do": [
          {
            "WorkflowStart": {
              "set": "${Object.entries($workflow.definition?.document?.metadata?.variables?.schema?.document?.properties || {}).reduce((acc, [name, def]) => ({ ...acc, [name]: def?.default }), {}) }",
              "output": { "as": "${$input}" },
              "export": { "as": "{ ...$context, variables: { ...$context.variables, ...$output } }" },
              "metadata": { "activityType": "Assign", "displayName": "Workflow start", "fullName": "Assign", "isTransparent": true }
            }
          },
          {
            "Do_While_Qoyod": {
              "for": { "in": "${ [1] }" },
              "doWhile": "${!$context.variables.done && $context.variables.attempt < ($workflow.input.maxAttempts || 60)}",
              "do": [
                {
                  "Do_While_Qoyod#Body": {
                    "do": [
                      {
                        "Wait_QoyodDraft": {
                          "wait": { "minutes": 0, "seconds": 5, "milliseconds": 0 },
                          "export": { "as": "{ ...$context, outputs: { ...$context?.outputs, \"Wait_QoyodDraft\": $output } }" },
                          "metadata": { "activityType": "Wait", "displayName": "Wait For Qoyod Draft Save", "fullName": "Wait" }
                        }
                      },
                      {
                        "HttpRequest_GetProgress": {
                          "call": "UiPath.Http",
                          "with": {
                            "connector": "uipath-uipath-http",
                            "connectionId": "ImplicitConnection",
                            "connectionResourceId": "ImplicitConnection",
                            "method": "POST",
                            "endpoint": "/http-request",
                            "bodyParameters": {
                              "authentication": "manual",
                              "method": "GET",
                              "url": "${$workflow.input.apiBaseUrl + '/api/case/batches/' + $workflow.input.batchId + '/progress'}",
                              "headers": { "x-case-token": "${$workflow.input.caseCallbackToken || ''}" }
                            }
                          },
                          "export": { "as": "{ ...$context, outputs: { ...$context?.outputs, \"qoyod_progress_response\": $output } }" },
                          "metadata": {
                            "fullName": "Connector",
                            "activityType": "Connector",
                            "displayName": "Get Qoyod Progress",
                            "uiPathActivityTypeId": "5c4cc855-b42a-37e6-b910-de8588998fce",
                            "assemblyQualifiedName": "Connector",
                            "configuration": "{\"essentialConfiguration\":{\"connectorVersion\":\"\",\"executionType\":null,\"customFieldsRequestDetails\":null,\"instanceParameters\":{\"version\":\"1.0.0\",\"connectorKey\":\"uipath-uipath-http\",\"activityType\":\"Curated\",\"objectName\":\"http-request\",\"httpMethod\":\"POST\",\"operation\":null,\"eventOperation\":null,\"eventMode\":null,\"connectorObjects\":null,\"previewEndpoint\":null},\"objectName\":\"http-request\",\"operation\":null,\"packageVersion\":\"1.0.0\",\"httpMethod\":\"POST\",\"path\":\"/http-request\",\"unifiedTypesCompatible\":true,\"savedJitInputFieldId\":\"in_http-request\"}}"
                          }
                        }
                      },
                      {
                        "Javascript_DecideQoyod": {
                          "run": {
                            "script": {
                              "code": "const response = $context.outputs.qoyod_progress_response || {}; const body = response.content || response.body || response; const progress = body.progress || body; const error = progress.flags?.hasErrors === true; const closed = progress.flags?.closed === true; const attempt = ($context.variables.attempt || 0) + 1; const max = Number($workflow.input.maxAttempts || 60); const timedOut = !error && !closed && attempt >= max; const nextStage = (error || timedOut) ? 'Exception Resolution' : closed ? 'Closed' : progress.nextStage; return { progress, attempt, done: error || closed || timedOut, caseStage: nextStage, caseStatus: (error || timedOut) ? 'exception' : closed ? 'closed' : 'active', taskStatus: (error || timedOut) ? 'failed' : closed ? 'completed' : 'waiting', callbackPath: (error || timedOut) ? '/api/case/batches/' + $workflow.input.batchId + '/exception' : closed ? '/api/case/batches/' + $workflow.input.batchId + '/close' : '/api/case/batches/' + $workflow.input.batchId + '/stage', errorCode: error ? (progress.errorCode || 'case_qoyod_error') : timedOut ? 'qoyod_fill_timeout' : '', errorMessage: error ? (progress.errorMessage || 'Qoyod drafting failed.') : timedOut ? 'Qoyod draft was not saved before the Maestro polling limit.' : '', qoyodDraftStatus: closed ? 'draft_saved' : 'waiting', qoyodDraftReference: (progress.references?.qoyodDraftReferences || [])[0] || '' };",
                              "language": "javascript",
                              "arguments": "${{ \"$context\": $context, \"$workflow\": $workflow, \"$input\": $input }}"
                            }
                          },
                          "export": { "as": "{ ...$context, outputs: { ...$context?.outputs, \"qoyod_decision\": $output } }" },
                          "metadata": { "activityType": "JsInvoke", "displayName": "Decide Qoyod Draft Progress", "fullName": "JsInvoke" }
                        }
                      },
                      {
                        "Assign_Decision": {
                          "set": { "decision": "${$context.outputs.qoyod_decision}", "attempt": "${$context.outputs.qoyod_decision.attempt}", "done": "${$context.outputs.qoyod_decision.done}" },
                          "export": { "as": "{ ...$context, variables: { ...$context.variables, ...$output } }" },
                          "metadata": { "activityType": "Assign", "displayName": "Store Qoyod Decision", "fullName": "Assign", "isTransparent": false }
                        }
                      }
                    ],
                    "export": { "as": "{ ...$context, outputs: { ...$context?.outputs, \"Do_While_Qoyod\": { ...$context?.outputs?.Do_While_Qoyod, results: [ ...($context?.outputs?.Do_While_Qoyod?.results ?? []), ...([$output] ?? []) ] } } }" }
                  }
                }
              ],
              "output": { "as": "${$context.outputs.Do_While_Qoyod}" },
              "metadata": { "activityType": "DoWhile", "displayName": "Poll Qoyod Draft Status", "fullName": "DoWhile" }
            }
          },
          {
            "HttpRequest_SyncQoyodStage": {
              "call": "UiPath.Http",
              "with": {
                "connector": "uipath-uipath-http",
                "connectionId": "ImplicitConnection",
                "connectionResourceId": "ImplicitConnection",
                "method": "POST",
                "endpoint": "/http-request",
                "bodyParameters": {
                  "authentication": "manual",
                  "method": "POST",
                  "url": "${$workflow.input.apiBaseUrl + $context.variables.decision.callbackPath}",
                  "headers": {
                    "content-type": "application/json",
                    "x-case-token": "${$workflow.input.caseCallbackToken || ''}"
                  },
                  "body": {
                    "workflowName": "WaitForQoyodExtensionDraft",
                    "taskName": "Wait For Qoyod Extension Draft Save",
                    "taskStatus": "${$context.variables.decision.taskStatus}",
                    "caseStage": "${$context.variables.decision.caseStage}",
                    "caseStatus": "${$context.variables.decision.caseStatus}",
                    "qoyodDraftReference": "${$context.variables.decision.qoyodDraftReference}",
                    "errorCode": "${$context.variables.decision.errorCode}",
                    "message": "${$context.variables.decision.errorMessage || 'Maestro Qoyod drafting workflow synchronized batch progress.'}"
                  }
                }
              },
              "export": { "as": "{ ...$context, outputs: { ...$context?.outputs, \"sync_qoyod_response\": $output } }" },
              "metadata": {
                "fullName": "Connector",
                "activityType": "Connector",
                "displayName": "Sync Qoyod Draft Stage",
                "uiPathActivityTypeId": "5c4cc855-b42a-37e6-b910-de8588998fce",
                "assemblyQualifiedName": "Connector",
                "configuration": "{\"essentialConfiguration\":{\"connectorVersion\":\"\",\"executionType\":null,\"customFieldsRequestDetails\":null,\"instanceParameters\":{\"version\":\"1.0.0\",\"connectorKey\":\"uipath-uipath-http\",\"activityType\":\"Curated\",\"objectName\":\"http-request\",\"httpMethod\":\"POST\",\"operation\":null,\"eventOperation\":null,\"eventMode\":null,\"connectorObjects\":null,\"previewEndpoint\":null},\"objectName\":\"http-request\",\"operation\":null,\"packageVersion\":\"1.0.0\",\"httpMethod\":\"POST\",\"path\":\"/http-request\",\"unifiedTypesCompatible\":true,\"savedJitInputFieldId\":\"in_http-request\"}}"
              }
            }
          },
          {
            "Response_1": {
              "response": "${{ caseStage: $context.variables.decision.caseStage, caseStatus: $context.variables.decision.caseStatus, taskStatus: $context.variables.decision.taskStatus, qoyodDraftStatus: $context.variables.decision.qoyodDraftStatus, qoyodDraftReference: $context.variables.decision.qoyodDraftReference, errorCode: $context.variables.decision.errorCode }}",
              "markJobAsFailed": false,
              "then": "end",
              "export": { "as": "{ ...$context, outputs: { ...$context?.outputs, \"Response_1\": $output } }" },
              "metadata": { "activityType": "Response", "displayName": "Response", "fullName": "Response" }
            }
          }
        ],
        "metadata": { "activityType": "Sequence", "displayName": "Sequence", "fullName": "Sequence" }
      }
    }
  ],
  "evaluate": { "mode": "strict", "language": "javascript" }
}
