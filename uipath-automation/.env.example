PORT=8787
PUBLIC_API_BASE_URL=http://localhost:8787
PUBLIC_WEB_APP_URL=http://localhost:5173

UIPATH_ENABLED=false
UIPATH_FOLDER_PATH=
UIPATH_BUCKET_KEY=
UIPATH_QUEUE_NAME=InvoiceIntake

UIPATH_START_CASE=false
UIPATH_CASE_FOLDER_KEY=
# Use the Maestro/Orchestrator ProcessKey string, not the process/release UUID Key.
# Example: QoyodInvoiceIntakeCase.case.Case
UIPATH_CASE_PROCESS_KEY=
# Use the Orchestrator process Key UUID as the Case release key.
UIPATH_CASE_RELEASE_KEY=
# Keep false in staging unless `uip maestro case process run --validate` works for Case packages.
UIPATH_CASE_VALIDATE_INPUTS=false
UIPATH_CASE_FEED_ID=
CASE_WORKFLOW_MAX_ATTEMPTS=60
CASE_WORKFLOW_WAIT_SECONDS=10

EXTRACTION_MODE=local
EXTRACTION_START_URL=
EXTRACTION_CALLBACK_TOKEN=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_EXTRACTION_MODEL=gpt-4.1
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

INTAKE_WEBHOOK_TOKEN=
FILLER_API_TOKEN=
CASE_CALLBACK_TOKEN=
DESTINATION_POST_TOKEN=

# Multi-destination release. Defaults to Qoyod for backward compatibility.
# Use "qoyod,erpnext" to release reviewed invoices to both destinations.
INVOICE_DESTINATIONS=qoyod

# ERPNext API destination. v1 always creates Purchase Invoice drafts only.
ERPNEXT_BASE_URL=
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=
ERPNEXT_COMPANY=
ERPNEXT_DEFAULT_EXPENSE_ACCOUNT=
ERPNEXT_DEFAULT_COST_CENTER=
ERPNEXT_DEFAULT_ITEM_CODE=
ERPNEXT_PURCHASE_TAXES_AND_CHARGES_TEMPLATE=
ERPNEXT_VAT_ACCOUNT_HEAD=
ERPNEXT_SUBMIT_AFTER_POST=false

# Explicit live smoke toggles. These touch real sandbox services only when true.
LIVE_ERPNEXT_TEST=false
LIVE_UIPATH_TEST=false
ERPNEXT_TEST_SUPPLIER=
ERPNEXT_TEST_SUPPLIER_TAX_ID=
ERPNEXT_TEST_CURRENCY=SAR
